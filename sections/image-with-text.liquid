<section id="ImageWithText-{{ section.id }}" class="image-with-text image-with-text--image-{{ section.settings.image_position }}">
  <div class="page-width">
    <div class="image-with-text__grid">
      <div class="image-with-text__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image | image_url: width: 1600 | image_tag: class: 'image-with-text__image', widths: '375, 550, 750, 1100, 1500, 1600', sizes: '(min-width: 48rem) 50vw, 100vw', loading: 'lazy'
          }}
        {% else %}
          {{
            'image' | placeholder_svg_tag: 'image-with-text__placeholder'
          }}
        {% endif %}
      </div>

      <div class="image-with-text__content">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'eyebrow' %}
              {% if block.settings.text != blank %}
                <p class="image-with-text__eyebrow" {{ block.shopify_attributes }}>
                  {{ block.settings.text | escape }}
                </p>
              {% endif %}

            {% when 'heading' %}
              {% if block.settings.heading != blank %}
                <h2 class="image-with-text__heading" {{ block.shopify_attributes }}>
                  {{ block.settings.heading | escape }}
                </h2>
              {% endif %}

            {% when 'text' %}
              {% if block.settings.text != blank %}
                <div class="image-with-text__text" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {% endif %}

            {% when 'button' %}
              {% if block.settings.label != blank and block.settings.link != blank %}
                <div class="image-with-text__button" {{ block.shopify_attributes }}>
                  <a class="button" href="{{ block.settings.link }}">
                    {{ block.settings.label | escape }}
                  </a>
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% style %}
  #ImageWithText-{{ section.id }} {
    --image-with-text-padding-top: {{ section.settings.padding_top }}px;
    --image-with-text-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{% stylesheet %}
  .image-with-text {
    padding-block: var(--image-with-text-padding-top) var(--image-with-text-padding-bottom);
  }

  .image-with-text__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
  }


  /*
   * Mobile always displays:
   * 1. Image
   * 2. Text
   */
  .image-with-text__media {
    order: 1;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: rgb(0 0 0 / 0.05);
  }

  .image-with-text__content {
    order: 2;
    width: min(100%, 36rem);
  }

  .image-with-text__image,
  .image-with-text__placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  .image-with-text__image {
    object-fit: cover;
  }

  .image-with-text__placeholder {
    background: rgb(0 0 0 / 0.05);
    fill: rgb(0 0 0 / 0.2);
  }

  .image-with-text__content > * {
    margin: 0;
  }

  .image-with-text__content > * + * {
    margin-top: 1.25rem;
  }

  .image-with-text__eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .image-with-text__heading {
    max-width: 14ch;
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .image-with-text__text {
    max-width: 60ch;
    font-size: 1rem;
    line-height: 1.65;
  }

  .image-with-text__text > :first-child {
    margin-top: 0;
  }

  .image-with-text__text > :last-child {
    margin-bottom: 0;
  }


  /*
   * Desktop switches to two columns.
   */
  @media screen and (min-width: 48rem) {
    .image-with-text__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }


    .image-with-text--image-left .image-with-text__media {
      order: 1;
    }

    .image-with-text--image-left .image-with-text__content {
      order: 2;
      justify-self: start;
    }

    .image-with-text--image-right .image-with-text__media {
      order: 2;
    }

    .image-with-text--image-right .image-with-text__content {
      order: 1;
      justify-self: end;
    }
  }
{% endstylesheet %}

{% schema %}
  {
    "name": "Image with text",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      }, {
        "type": "select",
        "id": "image_position",
        "label": "Image position",
        "default": "left",
        "info": "Choose which side the image appears on.",
        "options": [
          {
            "value": "left",
            "label": "Left"
          }, {
            "value": "right",
            "label": "Right"
          }
        ]
      }, {
        "type": "range",
        "id": "padding_top",
        "label": "Top spacing",
        "min": 0,
        "max": 160,
        "step": 8,
        "unit": "px",
        "default": 80
      }, {
        "type": "range",
        "id": "padding_bottom",
        "label": "Bottom spacing",
        "min": 0,
        "max": 160,
        "step": 8,
        "unit": "px",
        "default": 80
      }
    ],
    "max_blocks": 4,
    "blocks": [
      {
        "type": "eyebrow",
        "name": "Eyebrow",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Text",
            "default": "Built for boutiques"
          }
        ]
      }, {
        "type": "heading",
        "name": "Heading",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Thoughtful assortments without the guesswork"
          }
        ]
      }, {
        "type": "text",
        "name": "Text",
        "limit": 1,
        "settings": [
          {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>Shop curated seasonal groups designed to help independent retailers build cohesive collections.</p>"
          }
        ]
      }, {
        "type": "button",
        "name": "Button",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "label",
            "label": "Button label",
            "default": "Learn more"
          }, {
            "type": "url",
            "id": "link",
            "label": "Button link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Image with text",
        "blocks": [
          {
            "type": "eyebrow"
          }, {
            "type": "heading"
          }, {
            "type": "text"
          }, {
            "type": "button"
          }
        ]
      }
    ]
  }
{% endschema %}