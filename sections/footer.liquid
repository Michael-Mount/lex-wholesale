{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="site-footer" style="
    --footer-background: {{ section.settings.background_color }};
    --footer-text: {{ section.settings.text_color }};
    --footer-border: {{ section.settings.border_color }};
    --footer-columns: {{ section.settings.desktop_columns }};
  ">
  <div class="page-width">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a class="site-footer__brand-link" href="{{ routes.root_url }}">
          {{ shop.name | escape }}
        </a>

        {% if section.settings.description != blank %}
          <div class="site-footer__description">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.settings.show_social_links %}
          {% render 'social-links'
            , instagram_url: section.settings.instagram_url
            , facebook_url: section.settings.facebook_url
            , pinterest_url: section.settings.pinterest_url
            , linkedin_url: section.settings.linkedin_url
            , aria_label: 'Social media'
          %}
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="site-footer__blocks">
          {% for block in section.blocks %}
            <div class="site-footer__block" {{ block.shopify_attributes }}>
              {% case block.type %}
                {% when 'menu' %}
                  {% render 'footer-menu'
                    , menu: block.settings.menu
                    , heading: block.settings.heading
                    , section_id: section.id
                    , block_id: block.id
                  %}

                {% when 'text' %}
                  {% if block.settings.heading != blank %}
                    <h2 class="site-footer__block-heading">
                      {{ block.settings.heading | escape }}
                    </h2>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="site-footer__text">
                      {{ block.settings.text }}
                    </div>
                  {% endif %}
              {% endcase %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name | escape }}
      </p>

      {% if section.settings.legal_menu != blank %}
        <nav aria-label="Legal navigation">
          <ul class="site-footer__legal-list">
            {% for link in section.settings.legal_menu.links %}
              <li>
                <a
                  class="site-footer__link"
                  href="{{ link.url }}"
                  {% if link.current %}
                  aria-current="page"
                  {% endif %}>
                  {{ link.title | escape }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
  {
    "name": "Footer",
    "tag": "section",
    "class": "section-footer",
    "max_blocks": 6,
    "settings": [
      {
        "type": "richtext",
        "id": "description",
        "label": "Store description",
        "default": "<p>Wholesale clothing collections created for independent retailers.</p>"
      },
      {
        "type": "link_list",
        "id": "legal_menu",
        "label": "Legal menu"
      },
      {
        "type": "select",
        "id": "desktop_columns",
        "label": "Desktop block columns",
        "options": [
          {
            "value": "2",
            "label": "2 columns"
          }, {
            "value": "3",
            "label": "3 columns"
          }, {
            "value": "4",
            "label": "4 columns"
          }
        ],
        "default": "3"
      },
      {
        "type": "header",
        "content": "Social links"
      }, {
        "type": "checkbox",
        "id": "show_social_links",
        "label": "Show social links",
        "default": true
      }, {
        "type": "url",
        "id": "instagram_url",
        "label": "Instagram URL"
      }, {
        "type": "url",
        "id": "facebook_url",
        "label": "Facebook URL"
      }, {
        "type": "url",
        "id": "pinterest_url",
        "label": "Pinterest URL"
      }, {
        "type": "url",
        "id": "linkedin_url",
        "label": "LinkedIn URL"
      }, {
        "type": "header",
        "content": "Colors"
      }, {
        "type": "color",
        "id": "background_color",
        "label": "Background",
        "default": "#2c211c"
      }, {
        "type": "color",
        "id": "text_color",
        "label": "Text",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "border_color",
        "label": "Border",
        "default": "#62544d"
      }
    ],
    "blocks": [
      {
        "type": "menu",
        "name": "Menu",
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Quick links"
          }, {
            "type": "link_list",
            "id": "menu",
            "label": "Menu"
          }
        ]
      }, {
        "type": "text",
        "name": "Text",
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Information"
          }, {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>Add store information, showroom hours, or wholesale contact details.</p>"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Footer",
        "blocks": [
          {
            "type": "menu"
          }, {
            "type": "text"
          }
        ]
      }
    ],
    "enabled_on": {
      "groups": ["footer"]
    }
  }
{% endschema %}