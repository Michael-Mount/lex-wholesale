{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'component-collection-filters.css' | asset_url | stylesheet_tag }}
{{ 'section-main-collection.css' | asset_url | stylesheet_tag }}

{% liquid
  assign heading_id = 'CollectionHeading-' | append: section.id
  assign has_collection_image = false
  assign is_approved_customer = false
  assign has_restricted_price_request = false

  if section.settings.show_collection_image
    if collection.image != blank
      assign has_collection_image = true
    endif
  endif

  if customer
    if settings.approved_customer_tag != blank
      if customer.tags contains settings.approved_customer_tag
        assign is_approved_customer = true
      endif
    endif
  endif

  assign selected_sort_by = collection.sort_by | default: collection.default_sort_by

  unless is_approved_customer
    if selected_sort_by == 'price-ascending'
      assign has_restricted_price_request = true
    elsif selected_sort_by == 'price-descending'
      assign has_restricted_price_request = true
    endif

    for filter in collection.filters
      if filter.type == 'price_range'
        if filter.min_value.value != blank
          assign has_restricted_price_request = true
        elsif filter.max_value.value != blank
          assign has_restricted_price_request = true
        endif
      endif
    endfor
  endunless
%}

<section class="main-collection" style="
    --collection-background: {{ section.settings.background_color }};
    --collection-text: {{ section.settings.text_color }};
     --collection-border: {{ section.settings.card_border_color }};

    --collection-image-width: {{ section.settings.image_width }}%;
    --collection-image-fit: {{ section.settings.image_fit }};

    --collection-columns-desktop: {{ section.settings.desktop_columns }};
    --collection-columns-mobile: {{ section.settings.mobile_columns }};
    --collection-grid-gap: {{ section.settings.grid_gap }}px;

    --product-card-background: {{ section.settings.card_background_color }};
    --product-card-border: {{ section.settings.card_border_color }};

    --collection-padding-top: {{ section.settings.padding_top }}px;
    --collection-padding-bottom: {{ section.settings.padding_bottom }}px;
  ">
  <div class="page-width">
    <header class="
        main-collection__header

        {% if has_collection_image %}
          main-collection__header--with-image
        {% endif %}
      ">
      {% if has_collection_image %}
        <div class="
            main-collection__image-wrapper
            main-collection__image-wrapper--{{ section.settings.collection_image_ratio }}
          ">
          {% assign collection_image_alt = collection.image.alt | default: collection.title
          %}

          {{
            collection.image | image_url: width: 1600 | image_tag: class: 'main-collection__image', widths: '400, 600, 800, 1000, 1200, 1600', sizes: '(min-width: 990px) 40vw, 100vw', loading: 'eager', alt: collection_image_alt
          }}
        </div>
      {% endif %}

      <div class="main-collection__content">
        <h1 id="{{ heading_id }}" class="main-collection__title">
          {{ collection.title | escape }}
        </h1>

        {% if section.settings.show_description and collection.description != blank
        %}
          <div class="main-collection__description">
            {{ collection.description }}
          </div>
        {% endif %}

        {% if section.settings.show_product_count and has_restricted_price_request == false
        %}
          <p class="main-collection__product-count">
            {{ collection.products_count }}
            {% if collection.products_count == 1 %}
              product
            {% else %}
              products
            {% endif %}
          </p>
        {% endif %}
      </div>
    </header>

    <div class="
    main-collection__results-layout
    main-collection__results-layout--{{ section.settings.filter_layout }}
  ">
      <div class="main-collection__controls-column">
        {% render 'collection-filters'
          , collection: collection
          , section_id: section.id
          , is_approved_customer: is_approved_customer
          , show_filters: section.settings.enable_filtering
          , show_sorting: section.settings.enable_sorting
          , show_filter_counts: section.settings.show_filter_counts
          , show_filter_group_name: section.settings.show_filter_group_name
          , layout: section.settings.filter_layout
        %}
      </div>

      <div class="main-collection__products-column">
        {% if has_restricted_price_request %}
          <div class="main-collection__restricted">
            <h2 class="main-collection__restricted-heading">
              Wholesale approval required
            </h2>

            <p class="main-collection__restricted-text">
              Price-based filtering and sorting are available only to       
          approved wholesale customers.
            </p>

            {% unless customer %}
              <a class="main-collection__restricted-link" href="{{ routes.account_login_url }}">
                Sign in
              </a>
            {% endunless %}

            <a class="main-collection__restricted-link" href="{{ collection.url }}?sort_by=manual">
              Return to the collection
            </a>

            {% if request.design_mode %}
              <p class="main-collection__restricted-editor-note">
                Choose Manual, Best selling, Alphabetical, or Date as the       
            collection’s default sort order. A price-based default will
            block this collection for unapproved visitors.
              </p>
            {% endif %}
          </div>
        {% else %}
          {% paginate collection.products by section.settings.products_per_page
          %}
            {% if collection.products_count > 0 %}
              <div class="main-collection__grid" aria-labelledby="{{ heading_id }}">
                {% for product in collection.products %}
                  {% render 'product-card'
                    , product: product
                    , image_ratio: section.settings.product_image_ratio
                    , image_fit: section.settings.product_image_fit
                    , text_alignment: section.settings.text_alignment
                    , show_vendor: section.settings.show_vendor
                    , show_sold_out_badge: section.settings.show_sold_out_badge
                    , show_price_range: section.settings.show_price_range
                    , show_compare_at_price: section.settings.show_compare_at_price
                  %}
                {% endfor %}
              </div>

              {% render 'pagination'
                , paginate: paginate
                , aria_label: 'Collection pagination'
              %}
            {% else %}
              <div class="main-collection__empty">
                <h2 class="main-collection__empty-heading">
                  No products found
                </h2>

                <p class="main-collection__empty-text">
                  Try removing one or more filters.
                </p>

                <a class="main-collection__restricted-link" href="{{ collection.url }}?sort_by={{ selected_sort_by }}">
                  Clear filters
                </a>
              </div>
            {% endif %}
          {% endpaginate %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Main collection",
    "tag": "section",
    "class": "section-main-collection",
    "settings": [
      {
        "type": "header",
        "content": "Collection header"
      },
      {
        "type": "checkbox",
        "id": "show_collection_image",
        "label": "Show collection image",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_description",
        "label": "Show collection description",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_product_count",
        "label": "Show product count",
        "default": true
      }, {
        "type": "range",
        "id": "image_width",
        "min": 25,
        "max": 50,
        "step": 5,
        "unit": "%",
        "label": "Desktop image width",
        "default": 40
      }, {
        "type": "select",
        "id": "collection_image_ratio",
        "label": "Collection image ratio",
        "options": [
          {
            "value": "square",
            "label": "Square"
          }, {
            "value": "portrait",
            "label": "Portrait"
          }, {
            "value": "landscape",
            "label": "Landscape"
          }
        ],
        "default": "landscape"
      }, {
        "type": "select",
        "id": "image_fit",
        "label": "Collection image fit",
        "options": [
          {
            "value": "cover",
            "label": "Crop to fill"
          }, {
            "value": "contain",
            "label": "Fit entire image"
          }
        ],
        "default": "cover"
      }, {
        "type": "header",
        "content": "Filtering and sorting"
      }, {
        "type": "checkbox",
        "id": "enable_filtering",
        "label": "Enable filtering",
        "default": true
      }, {
        "type": "checkbox",
        "id": "enable_sorting",
        "label": "Enable sorting",
        "default": true
      }, {
        "type": "select",
        "id": "filter_layout",
        "label": "Desktop filter layout",
        "options": [
          {
            "value": "horizontal",
            "label": "Horizontal toolbar"
          }, {
            "value": "sidebar",
            "label": "Sidebar"
          }
        ],
        "default": "horizontal"
      }, {
        "type": "checkbox",
        "id": "show_filter_counts",
        "label": "Show result count beside filter values",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_filter_group_name",
        "label": "Include group name in active filters",
        "default": false
      }, {
        "type": "header",
        "content": "Product grid"
      }, {
        "type": "range",
        "id": "products_per_page",
        "min": 8,
        "max": 48,
        "step": 4,
        "label": "Products per page",
        "default": 16
      }, {
        "type": "select",
        "id": "desktop_columns",
        "label": "Desktop columns",
        "options": [
          {
            "value": "2",
            "label": "2 columns"
          }, {
            "value": "3",
            "label": "3 columns"
          }, {
            "value": "4",
            "label": "4 columns"
          }, {
            "value": "5",
            "label": "5 columns"
          }
        ],
        "default": "4"
      }, {
        "type": "select",
        "id": "mobile_columns",
        "label": "Mobile columns",
        "options": [
          {
            "value": "1",
            "label": "1 column"
          }, {
            "value": "2",
            "label": "2 columns"
          }
        ],
        "default": "2"
      }, {
        "type": "range",
        "id": "grid_gap",
        "min": 8,
        "max": 40,
        "step": 4,
        "unit": "px",
        "label": "Grid spacing",
        "default": 24
      }, {
        "type": "header",
        "content": "Product cards"
      }, {
        "type": "select",
        "id": "product_image_ratio",
        "label": "Product image ratio",
        "options": [
          {
            "value": "square",
            "label": "Square"
          }, {
            "value": "portrait",
            "label": "Portrait"
          }, {
            "value": "landscape",
            "label": "Landscape"
          }
        ],
        "default": "portrait"
      }, {
        "type": "select",
        "id": "product_image_fit",
        "label": "Product image fit",
        "options": [
          {
            "value": "cover",
            "label": "Crop to fill"
          }, {
            "value": "contain",
            "label": "Fit entire image"
          }
        ],
        "default": "cover"
      }, {
        "type": "select",
        "id": "text_alignment",
        "label": "Product text alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          }, {
            "value": "center",
            "label": "Center"
          }
        ],
        "default": "left"
      }, {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show vendor",
        "default": false
      }, {
        "type": "checkbox",
        "id": "show_sold_out_badge",
        "label": "Show sold-out badge",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_price_range",
        "label": "Show starting price for varying prices",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_compare_at_price",
        "label": "Show compare-at price",
        "default": true
      }, {
        "type": "header",
        "content": "Colors"
      }, {
        "type": "color",
        "id": "background_color",
        "label": "Section background",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "text_color",
        "label": "Section text",
        "default": "#231f1c"
      }, {
        "type": "color",
        "id": "card_background_color",
        "label": "Product card background",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "card_border_color",
        "label": "Product card border",
        "default": "#ded8d3"
      }, {
        "type": "header",
        "content": "Spacing"
      }, {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Top padding",
        "default": 64
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Bottom padding",
        "default": 64
      }
    ]
  }
{% endschema %}