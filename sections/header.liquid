{% assign logo_alt = section.settings.logo.alt
  | default: shop.name
  | escape
%}

<header
  id="SiteHeader-{{ section.id }}"
  class="site-header"
>
  <div class="page-width site-header__inner">
    <a
      class="site-header__brand"
      href="{{ routes.root_url }}"
    >
      {% if section.settings.logo != blank %}
        {{
          section.settings.logo
          | image_url: width: 600
          | image_tag:
            class: 'site-header__logo',
            widths: '120, 180, 240, 360, 480, 600',
            alt: logo_alt
        }}
      {% else %}
        <span class="site-header__wordmark">
          {{ shop.name | escape }}
        </span>
      {% endif %}
    </a>

    {% if section.settings.menu != blank %}
      <nav
        class="site-header__nav"
        aria-label="Primary navigation"
      >
        <ul class="site-header__menu" role="list">
          {% for link in section.settings.menu.links %}
            <li>
              <a
                class="
                  site-header__link
                  {% if link.current %}
                    site-header__link--current
                  {% endif %}
                "
                href="{{ link.url }}"
                {% if link.current %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title | escape }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <div class="site-header__actions">
      {% if shop.customer_accounts_enabled %}
        {% if customer %}
          <a
            class="site-header__action site-header__account"
            href="{{ routes.account_url }}"
          >
            Account
          </a>
        {% else %}
          <a
            class="site-header__action site-header__account"
            href="{{ routes.account_login_url }}"
          >
            Sign in
          </a>
        {% endif %}
      {% endif %}

      <a
        class="site-header__action"
        href="{{ routes.cart_url }}"
      >
        Cart
        <span aria-hidden="true">
          ({{ cart.item_count }})
        </span>
      </a>
    </div>

    {% if section.settings.menu != blank %}
      <details class="mobile-menu">
        <summary class="mobile-menu__summary">
          Menu
        </summary>

        <nav
          class="mobile-menu__panel"
          aria-label="Mobile navigation"
        >
          <ul class="mobile-menu__list" role="list">
            {% for link in section.settings.menu.links %}
              <li>
                <a
                  class="mobile-menu__link"
                  href="{{ link.url }}"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  {{ link.title | escape }}
                </a>
              </li>
            {% endfor %}

            {% if shop.customer_accounts_enabled %}
              <li class="mobile-menu__account-item">
                {% if customer %}
                  <a
                    class="mobile-menu__link"
                    href="{{ routes.account_url }}"
                  >
                    Account
                  </a>
                {% else %}
                  <a
                    class="mobile-menu__link"
                    href="{{ routes.account_login_url }}"
                  >
                    Sign in
                  </a>
                {% endif %}
              </li>
            {% endif %}
          </ul>
        </nav>
      </details>
    {% endif %}
  </div>
</header>

{% style %}
  #SiteHeader-{{ section.id }} {
    --header-background:
      {{ section.settings.background_color }};

    --header-text:
      {{ section.settings.text_color }};

    --header-logo-width:
      {{ section.settings.logo_width }}px;
  }
{% endstyle %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 260,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f7f3ee"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2f241d"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}