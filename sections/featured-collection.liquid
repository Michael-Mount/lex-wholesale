{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}

{% liquid
  assign featured_collection = section.settings.collection
  assign heading_id = 'FeaturedCollectionHeading-' | append: section.id
%}

<div class="featured-collection" style="
    --featured-background: {{ section.settings.background_color }};
    --featured-text: {{ section.settings.text_color }};

    --product-card-background: {{ section.settings.card_background_color }};
    --product-card-border: {{ section.settings.card_border_color }};

    --featured-columns-desktop: {{ section.settings.desktop_columns }};
    --featured-columns-mobile: {{ section.settings.mobile_columns }};
    --featured-grid-gap: {{ section.settings.grid_gap }}px;

    --featured-padding-top: {{ section.settings.padding_top }}px;
    --featured-padding-bottom: {{ section.settings.padding_bottom }}px;
  ">
  <div class="page-width">
    <div class="featured-collection__header">
      <div class="featured-collection__heading-group">
        {% if section.settings.heading != blank %}
          <h2 id="{{ heading_id }}" class="featured-collection__heading">
            {{ section.settings.heading | escape }}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="featured-collection__text">
            {{ section.settings.text }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.show_view_all and featured_collection != blank
      %}
        <a class="featured-collection__view-all" href="{{ featured_collection.url }}">
          {{ section.settings.view_all_label | escape }}
        </a>
      {% endif %}
    </div>

    {% if featured_collection != blank and featured_collection.products_count > 0
    %}
      <div
        class="featured-collection__grid"
        {% if section.settings.heading != blank %}
        aria-labelledby="{{ heading_id }}"
        {% endif %}>
        {% for product in featured_collection.products limit: section.settings.products_to_show
        %}
          {% render 'product-card'
            , product: product
            , image_ratio: section.settings.image_ratio
            , image_fit: section.settings.image_fit
            , text_alignment: section.settings.text_alignment
            , show_vendor: section.settings.show_vendor
            , show_sold_out_badge: section.settings.show_sold_out_badge
            , show_price_range: section.settings.show_price_range
            , show_compare_at_price: section.settings.show_compare_at_price
          %}
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="featured-collection__empty">
        <p>
          Select a collection containing products in the section settings.
        </p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
  {
    "name": "Featured collection",
    "tag": "section",
    "class": "section-featured-collection",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Featured collection"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Description",
        "default": "<p>Explore a curated selection from our latest wholesale collection.</p>"
      },
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      },
      {
        "type": "range",
        "id": "products_to_show",
        "min": 2,
        "max": 12,
        "step": 1,
        "label": "Products to show",
        "default": 4
      }, {
        "type": "select",
        "id": "desktop_columns",
        "label": "Desktop columns",
        "options": [
          {
            "value": "2",
            "label": "2 columns"
          }, {
            "value": "3",
            "label": "3 columns"
          }, {
            "value": "4",
            "label": "4 columns"
          }, {
            "value": "5",
            "label": "5 columns"
          }
        ],
        "default": "4"
      }, {
        "type": "select",
        "id": "mobile_columns",
        "label": "Mobile columns",
        "options": [
          {
            "value": "1",
            "label": "1 column"
          }, {
            "value": "2",
            "label": "2 columns"
          }
        ],
        "default": "2"
      }, {
        "type": "range",
        "id": "grid_gap",
        "min": 8,
        "max": 40,
        "step": 4,
        "unit": "px",
        "label": "Grid spacing",
        "default": 24
      }, {
        "type": "header",
        "content": "Product cards"
      }, {
        "type": "select",
        "id": "image_ratio",
        "label": "Image ratio",
        "options": [
          {
            "value": "square",
            "label": "Square"
          }, {
            "value": "portrait",
            "label": "Portrait"
          }, {
            "value": "landscape",
            "label": "Landscape"
          }
        ],
        "default": "portrait"
      }, {
        "type": "select",
        "id": "image_fit",
        "label": "Image fit",
        "options": [
          {
            "value": "cover",
            "label": "Crop to fill"
          }, {
            "value": "contain",
            "label": "Fit entire image"
          }
        ],
        "default": "cover"
      }, {
        "type": "select",
        "id": "text_alignment",
        "label": "Text alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          }, {
            "value": "center",
            "label": "Center"
          }
        ],
        "default": "left"
      }, {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show vendor",
        "default": false
      }, {
        "type": "checkbox",
        "id": "show_sold_out_badge",
        "label": "Show sold-out badge",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_price_range",
        "label": "Show starting price for products with varying prices",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_compare_at_price",
        "label": "Show compare-at price",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_view_all",
        "label": "Show view-all link",
        "default": true
      }, {
        "type": "text",
        "id": "view_all_label",
        "label": "View-all label",
        "default": "View entire collection"
      }, {
        "type": "header",
        "content": "Colors"
      }, {
        "type": "color",
        "id": "background_color",
        "label": "Section background",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "text_color",
        "label": "Section text",
        "default": "#231f1c"
      }, {
        "type": "color",
        "id": "card_background_color",
        "label": "Card background",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "card_border_color",
        "label": "Card border",
        "default": "#ded8d3"
      }, {
        "type": "header",
        "content": "Spacing"
      }, {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Top padding",
        "default": 64
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Bottom padding",
        "default": 64
      }
    ],
    "presets": [
      {
        "name": "Featured collection"
      }
    ]
  }
{% endschema %}