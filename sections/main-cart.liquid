{{ 'section-main-cart.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart-page.js' | asset_url }}" defer></script>

{% liquid
  assign is_approved_customer = false
  assign cart_form_id = 'CartForm-' | append: section.id
  assign cart_heading_id = 'CartHeading-' | append: section.id
  assign cart_status_id = 'CartStatus-' | append: section.id
  assign cart_note_id = 'CartNote-' | append: section.id
  assign continue_shopping_url = section.settings.continue_shopping_url

  if continue_shopping_url == blank
    assign continue_shopping_url = routes.root_url
  endif

  if customer
    if settings.approved_customer_tag != blank
      if customer.tags contains settings.approved_customer_tag
        assign is_approved_customer = true
      endif
    endif
  endif
%}

<section
  class="main-cart"
  data-main-cart
  data-section-id="{{ section.id }}"
  style="
    --cart-background: {{ section.settings.background_color }};
    --cart-text: {{ section.settings.text_color }};
    --cart-border: {{ section.settings.border_color }};
    --cart-button-background: {{ section.settings.button_background_color }};
    --cart-button-text: {{ section.settings.button_text_color }};
    --cart-image-width: {{ section.settings.image_width }}px;
    --cart-padding-top: {{ section.settings.padding_top }}px;
    --cart-padding-bottom: {{ section.settings.padding_bottom }}px;
  ">
  <div class="page-width">
    <header class="main-cart__header">
      <h1 id="{{ cart_heading_id }}" class="main-cart__heading">
        {{ section.settings.heading | escape }}
      </h1>

      {% unless cart.empty? %}
        <p class="main-cart__item-count">
          {{ cart.item_count }}

          {% if cart.item_count == 1 %}
            item
          {% else %}
            items
          {% endif %}
        </p>
      {% endunless %}
    </header>

    <p
      id="{{ cart_status_id }}"
      class="main-cart__status"
      data-cart-status
      role="status"
      aria-live="polite"></p>

    {% if cart.empty? %}
      <div class="main-cart__empty">
        <h2 class="main-cart__empty-heading">
          {{ section.settings.empty_heading | escape }}
        </h2>

        {% if section.settings.empty_text != blank %}
          <p class="main-cart__empty-text">
            {{ section.settings.empty_text | escape }}
          </p>
        {% endif %}

        <a class="main-cart__button main-cart__button--primary" href="{{ continue_shopping_url }}">
          {{ section.settings.continue_shopping_label | escape }}
        </a>
      </div>
    {% else %}
      {% form 'cart'
        , cart
        , id: cart_form_id
        , class: 'main-cart__form'
      %}
        <div class="main-cart__layout">
          <div class="main-cart__items-column">
            <ul
              class="main-cart__items"
              data-bundle-group-container
              data-enable-bundle-groups="{{ settings.show_bundle_cart_groups }}"
              data-bundle-group-label="{{ settings.bundle_group_label | escape }}"
              data-bundle-complete-label="{{ settings.bundle_complete_label | escape }}"
              data-bundle-incomplete-label="{{ settings.bundle_incomplete_label | escape }}"
              data-bundle-incomplete-warning="{{ settings.bundle_incomplete_warning | escape }}"
              data-bundle-unknown-warning="{{ settings.bundle_unknown_warning | escape }}">
              {% for item in cart.items %}
                <li
                  class="main-cart__item"
                  data-cart-line
                  data-cart-line-index="{{ forloop.index }}"
                  {% if is_approved_customer %}
                  data-line-key="{{ item.key | escape }}"

                  {% render 'bundle-line-metadata', item: item, output: 'attributes' %}
                  {% endif %}>
                  <a
                    class="main-cart__image-link"
                    href="{{ item.url }}"
                    tabindex="-1"
                    aria-hidden="true">
                    {% if item.image != blank %}
                      {{
                        item.image | image_url: width: 600 | image_tag: class: 'main-cart__image', widths: '160, 240, 320, 480, 600', sizes: '160px', loading: 'lazy', alt: ''
                      }}
                    {% else %}
                      <span class="main-cart__image-placeholder"></span>
                    {% endif %}
                  </a>

                  <div class="main-cart__item-information">
                    <div class="main-cart__item-heading">
                      <div>
                        {% if section.settings.show_vendor and item.vendor != blank
                        %}
                          <p class="main-cart__vendor">
                            {{ item.vendor | escape }}
                          </p>
                        {% endif %}

                        <h2 class="main-cart__product-title">
                          <a class="main-cart__product-link" href="{{ item.url }}">
                            {{ item.product.title | escape }}
                          </a>
                        </h2>
                        {% if is_approved_customer %}
                          {% render 'bundle-line-metadata'
                            , item: item
                            , output: 'label'
                          %}
                        {% endif %}
                      </div>

                      {% if is_approved_customer %}
                        <div class="main-cart__line-total">
                          {% if item.original_line_price > item.final_line_price
                          %}
                            <s class="main-cart__original-line-price">
                              <span class="visually-hidden">
                                Original line price
                              </span>

                              {{ item.original_line_price | money }}
                            </s>
                          {% endif %}

                          <strong>
                            <span class="visually-hidden">
                              Line total
                            </span>

                            {{ item.final_line_price | money }}
                          </strong>
                        </div>
                      {% endif %}
                    </div>

                    {% unless item.product.has_only_default_variant %}
                      <dl class="main-cart__options">
                        {% for option in item.options_with_values %}
                          <div class="main-cart__option">
                            <dt>{{ option.name | escape }}:</dt>
                            <dd>{{ option.value | escape }}</dd>
                          </div>
                        {% endfor %}
                      </dl>
                    {% endunless %}

                    {% if section.settings.show_sku and item.sku != blank
                    %}
                      <p class="main-cart__sku">
                        SKU: {{ item.sku | escape }}
                      </p>
                    {% endif %}

                    {% if section.settings.show_line_properties and item.properties != empty
                    %}
                      <dl class="main-cart__properties">
                        {% for property in item.properties %}
                          {% assign property_first_character = property.first | slice: 0 %}

                          {% if property.last != blank and property_first_character != '_'
                          %}
                            <div class="main-cart__property">
                              <dt>{{ property.first | escape }}:</dt>

                              <dd>
                                {% if property.last contains '/uploads/' %}
                                  <a
                                    href="{{ property.last }}"
                                    target="_blank"
                                    rel="noopener">
                                    {{ property.last | split: '/' | last }}
                                  </a>
                                {% else %}
                                  {{ property.last | escape }}
                                {% endif %}
                              </dd>
                            </div>
                          {% endif %}
                        {% endfor %}
                      </dl>
                    {% endif %}

                    {% if item.error_message != blank %}
                      <p class="main-cart__line-error" role="alert">
                        {{ item.error_message | escape }}
                      </p>
                    {% endif %}

                    {% if is_approved_customer %}
                      <div class="main-cart__item-pricing">
                        {% if item.original_price > item.final_price %}
                          <s>
                            <span class="visually-hidden">
                              Original unit price
                            </span>

                            {{ item.original_price | money }}
                          </s>
                        {% endif %}

                        <span>
                          <span class="visually-hidden">
                            Unit price
                          </span>

                          {{ item.final_price | money }} each
                        </span>
                      </div>

                      {% if item.line_level_discount_allocations.size > 0 %}
                        <ul class="main-cart__discounts">
                          {% for allocation in item.line_level_discount_allocations %}
                            <li>
                              <span>
                                {{ allocation.discount_application.title | escape }}
                              </span>

                              <span>
                                −{{ allocation.amount | money }}</span>
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}

                      <div class="main-cart__item-actions">
                        <div class="main-cart__quantity">
                          <label class="main-cart__quantity-label" for="CartQuantity-{{ section.id }}-{{ forloop.index }}">
                            Quantity
                          </label>

                          <div class="main-cart__quantity-controls">
                            <button
                              class="main-cart__quantity-button"
                              type="button"
                              data-cart-quantity-adjust="decrease"
                              data-cart-control
                              aria-label="Decrease quantity for {{ item.product.title | escape }}">
                              <span aria-hidden="true">−</span>
                            </button>

                            <input
                              id="CartQuantity-{{ section.id }}-{{ forloop.index }}"
                              class="main-cart__quantity-input"
                              type="number"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              min="0"
                              inputmode="numeric"
                              pattern="[0-9]*"
                              data-cart-quantity-input
                              data-cart-control
                              aria-label="Quantity for {{ item.product.title | escape }}">

                            <button
                              class="main-cart__quantity-button"
                              type="button"
                              data-cart-quantity-adjust="increase"
                              data-cart-control
                              aria-label="Increase quantity for {{ item.product.title | escape }}">
                              <span aria-hidden="true">+</span>
                            </button>
                          </div>
                        </div>

                        <a
                          class="main-cart__remove"
                          href="{{ item.url_to_remove }}"
                          data-cart-remove
                          data-cart-control>
                          Remove

                          <span class="visually-hidden">
                            {{ item.product.title | escape }}
                          </span>
                        </a>
                      </div>
                    {% else %}
                      <p class="main-cart__static-quantity">
                        Quantity: {{ item.quantity }}
                      </p>
                    {% endif %}
                  </div>
                </li>
              {% endfor %}
            </ul>

            {% if is_approved_customer %}
              <button
                class="main-cart__update-fallback"
                type="submit"
                name="update">
                {{ section.settings.update_cart_label | escape }}
              </button>
            {% endif %}
          </div>

          <aside class="main-cart__summary-column">
            {% if is_approved_customer %}
              {% if section.settings.show_order_note %}
                <div class="main-cart__note">
                  <label class="main-cart__note-label" for="{{ cart_note_id }}">
                    {{ section.settings.order_note_label | escape }}
                  </label>

                  <textarea
                    id="{{ cart_note_id }}"
                    class="main-cart__note-input"
                    name="note"
                    rows="5"
                    placeholder="{{ section.settings.order_note_placeholder | escape }}"
                    data-cart-note
                    data-cart-control>{{ cart.note | escape }}</textarea>

                  <button
                    class="main-cart__save-note"
                    type="button"
                    data-cart-note-save
                    data-cart-control>
                    {{ section.settings.save_note_label | escape }}
                  </button>
                </div>
              {% endif %}

              <div class="main-cart__summary">
                <h2 class="main-cart__summary-heading">
                  Order summary
                </h2>

                <div class="main-cart__summary-row">
                  <span>Subtotal</span>

                  <span>
                    {{ cart.items_subtotal_price | money }}
                  </span>
                </div>

                {% for discount_application in cart.cart_level_discount_applications %}
                  <div class="
                      main-cart__summary-row
                      main-cart__summary-row--discount
                    ">
                    <span>
                      {{ discount_application.title | escape }}
                    </span>

                    <span>
                      −{{ discount_application.total_allocated_amount | money }}</span>
                  </div>
                {% endfor %}

                <div class="
                    main-cart__summary-row
                    main-cart__summary-row--total
                  ">
                  <strong>Estimated total</strong>

                  <strong>
                    {{ cart.total_price | money }}
                  </strong>
                </div>

                <p class="main-cart__summary-note">
                  Shipping and taxes are calculated at checkout.
                </p>

                <button
                  class="main-cart__checkout"
                  type="submit"
                  name="checkout">
                  {{ section.settings.checkout_label | escape }}
                </button>

                <a class="main-cart__continue-link" href="{{ continue_shopping_url }}">
                  {{ section.settings.continue_shopping_label | escape }}
                </a>
              </div>
            {% else %}
              <div class="main-cart__access-gate">
                <h2 class="main-cart__access-heading">
                  Wholesale approval required
                </h2>

                <p class="main-cart__access-message">
                  {% if customer %}
                    {{ settings.unapproved_price_message | escape }}
                  {% else %}
                    {{ settings.locked_price_message | escape }}
                  {% endif %}
                </p>

                <div class="main-cart__access-actions">
                  {% unless customer %}
                    <a class="main-cart__button main-cart__button--primary" href="{{ routes.account_login_url }}">
                      Sign in
                    </a>
                  {% endunless %}

                  {% if settings.wholesale_application_url != blank %}
                    <a class="main-cart__button main-cart__button--secondary" href="{{ settings.wholesale_application_url }}">
                      {{ settings.wholesale_application_label | escape }}
                    </a>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </aside>
        </div>
      {% endform %}
    {% endif %}
  </div>
</section>

{% schema %}
  {
    "name": "Main cart",
    "tag": "section",
    "class": "section-main-cart",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Your cart"
      },
      {
        "type": "text",
        "id": "empty_heading",
        "label": "Empty cart heading",
        "default": "Your cart is empty"
      },
      {
        "type": "textarea",
        "id": "empty_text",
        "label": "Empty cart text",
        "default": "Browse our collections to begin building your wholesale order."
      },
      {
        "type": "url",
        "id": "continue_shopping_url",
        "label": "Continue shopping link"
      }, {
        "type": "text",
        "id": "continue_shopping_label",
        "label": "Continue shopping label",
        "default": "Continue shopping"
      }, {
        "type": "header",
        "content": "Line items"
      }, {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show product vendor",
        "default": false
      }, {
        "type": "checkbox",
        "id": "show_sku",
        "label": "Show variant SKU",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_line_properties",
        "label": "Show public line item properties",
        "default": true
      }, {
        "type": "range",
        "id": "image_width",
        "min": 80,
        "max": 220,
        "step": 20,
        "unit": "px",
        "label": "Product image width",
        "default": 140
      }, {
        "type": "text",
        "id": "update_cart_label",
        "label": "Update cart label",
        "default": "Update cart"
      }, {
        "type": "header",
        "content": "Order note"
      }, {
        "type": "checkbox",
        "id": "show_order_note",
        "label": "Show order note",
        "default": true
      }, {
        "type": "text",
        "id": "order_note_label",
        "label": "Order note label",
        "default": "Order notes"
      }, {
        "type": "textarea",
        "id": "order_note_placeholder",
        "label": "Order note placeholder",
        "default": "Add delivery instructions or other information for this order."
      }, {
        "type": "text",
        "id": "save_note_label",
        "label": "Save note label",
        "default": "Save note"
      }, {
        "type": "text",
        "id": "checkout_label",
        "label": "Checkout label",
        "default": "Proceed to checkout"
      }, {
        "type": "header",
        "content": "Colors"
      }, {
        "type": "color",
        "id": "background_color",
        "label": "Background",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "text_color",
        "label": "Text",
        "default": "#231f1c"
      }, {
        "type": "color",
        "id": "border_color",
        "label": "Borders",
        "default": "#ded8d3"
      }, {
        "type": "color",
        "id": "button_background_color",
        "label": "Primary button background",
        "default": "#231f1c"
      }, {
        "type": "color",
        "id": "button_text_color",
        "label": "Primary button text",
        "default": "#ffffff"
      }, {
        "type": "header",
        "content": "Spacing"
      }, {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Top padding",
        "default": 64
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 120,
        "step": 8,
        "unit": "px",
        "label": "Bottom padding",
        "default": 80
      }
    ]
  }
{% endschema %}