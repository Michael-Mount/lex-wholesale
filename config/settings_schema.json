[
  {
    "name": "theme_info",
    "theme_name": "Lex Wholesale Theme",
    "theme_version": "0.1.0",
    "theme_author": "Michael Mount",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 800,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "default": 1200
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Page background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Page text",
        "default": "#231f1c"
      }
    ]
  },
  {
    "name": "Wholesale access",
    "settings": [
      {
        "type": "text",
        "id": "approved_customer_tag",
        "label": "Approved customer tag",
        "info": "Customers with this Shopify customer tag are treated as approved wholesale customers.",
        "default": "approved-wholesale"
      }
    ]
  }
]
