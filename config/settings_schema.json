[
  {
    "name": "theme_info",
    "theme_name": "Lex Wholesale Theme",
    "theme_version": "0.1.0",
    "theme_author": "Michael Mount",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 800,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Maximum page width",
        "default": 1200
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text",
        "default": "#231f1c"
      }
    ]
  },
  {
    "name": "Wholesale access",
    "settings": [
      {
        "type": "text",
        "id": "approved_customer_tag",
        "label": "Approved customer tag",
        "default": "wholesale-approved",
        "info": "Customers with this tag can view prices and purchase products."
      },
      {
        "type": "textarea",
        "id": "locked_price_message",
        "label": "Hidden price message",
        "default": "Sign in with an approved wholesale account to view pricing."
      }
    ]
  }
]
