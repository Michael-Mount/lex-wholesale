[
  {
    "name": "theme_info",
    "theme_name": "Lex Wholesale Theme",
    "theme_version": "0.1.0",
    "theme_author": "Michael Mount",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 800,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "default": 1200
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "assistant_n7"
      },
      {
        "type": "range",
        "id": "body_font_size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Base font size",
        "default": 16
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Page background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Page text",
        "default": "#231f1c"
      }
    ]
  },
  {
    "name": "Wholesale access",
    "settings": [
      {
        "type": "text",
        "id": "approved_customer_tag",
        "label": "Approved customer tag",
        "default": "wholesale-approved",
        "info": "Customers with this tag can view prices and purchase products."
      },
      {
        "type": "textarea",
        "id": "locked_price_message",
        "label": "Logged-out price message",
        "default": "Sign in with an approved wholesale account to view pricing."
      },
      {
        "type": "textarea",
        "id": "unapproved_price_message",
        "label": "Unapproved account message",
        "default": "Your account has not been approved for wholesale pricing."
      },
      {
        "type": "url",
        "id": "wholesale_application_url",
        "label": "Wholesale application link"
      },
      {
        "type": "text",
        "id": "wholesale_application_label",
        "label": "Wholesale application label",
        "default": "Apply for wholesale access"
      }
    ]
  }
]
