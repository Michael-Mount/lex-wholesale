<article class="product-card">
  <a class="product-card__link" href="{{ card_product.url }}">
    <div class="product-card__media">
      {% if card_product.featured_image != blank %}
        {{
          card_product.featured_image | image_url: width: 900 | image_tag: class: 'product-card__image', widths: '360, 540, 720, 900', sizes: '(min-width: 48rem) 33vw, 100vw', loading: 'lazy'
        }}
      {% else %}
        {{
          'product-1' | placeholder_svg_tag: 'product-card__placeholder'
        }}
      {% endif %}
    </div>
    <div class="product-card__content">
      <h3 class="product-card__title">
        {{ card_product.title | escape }}
      </h3>
      <p class="product-card__price">
        {{ card_product.price | money }}
      </p>
    </div>
  </a>
</article>

{% stylesheet %}
  .featured-product-card {
    padding-block: 5rem;
  }

  .product-card {
    width: min(100%, 24rem);
  }

  .product-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .product-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: rgb(0 0 0 / 0.05);
  }

  .product-card__image,
  .product-card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  .product-card__image {
    object-fit: cover;
    transform: scale(1.001);
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-card__link:hover .product-card__image,
  .product-card__link:focus-visible .product-card__image {
    transform: scale(1.04);
  }

  .product-card__placeholder {
    fill: rgb(0 0 0 / 0.18);
  }

  .product-card__content {
    padding-top: 1rem;
  }

  .product-card__title,
  .product-card__price {
    margin: 0;
  }

  .product-card__title {
    font-size: 1rem;
    line-height: 1.3;
  }

  .product-card__title::after {
    content: "↗";
    display: inline-block;
    margin-inline-start: 0.4rem;
    transform: translate(0, 0);
    transition: transform 180ms ease;
  }

  .product-card__link:hover .product-card__title::after,
  .product-card__link:focus-visible .product-card__title::after {
    transform: translate(0.2rem, -0.2rem);
  }

  .product-card__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 0.3rem;
  }

  .product-card__price {
    margin-top: 0.4rem;
    font-size: 0.9375rem;
    line-height: 1.4;
  }

  @media (prefers-reduced-motion: reduce) {
    .button,
    .site-header__link::after,
    .product-card__image,
    .product-card__title::after {
      transition: none;
    }
  }

{% endstylesheet %}