{% comment %}
  Renders all product media.

  Required:
  - product

  Optional:
  - media_layout: stacked or grid
  - image_fit: cover or contain
  - image_ratio: natural, square, portrait
{% endcomment %}

<div class="
    product-media
    product-media--{{ media_layout | default: 'grid' }}
  " style="
    --product-media-fit: {{ image_fit | default: 'cover' }};
  ">
  {% if product.media.size > 0 %}
    <div class="product-media__list">
      {% for media in product.media %}
        <div
          id="ProductMedia-{{ section.id }}-{{ media.id }}"
          class="
            product-media__item
            product-media__item--{{ media.media_type }}
            product-media__item--{{ image_ratio | default: 'natural' }}
          "
          data-media-id="{{ media.id }}">
          {% case media.media_type %}
            {% when 'image' %}
              {% assign media_alt = media.alt | default: product.title %}

              {{
                media.preview_image | image_url: width: 1800 | image_tag: class: 'product-media__image', widths: '400, 600, 800, 1000, 1200, 1500, 1800', sizes: '(min-width: 990px) 55vw, 100vw', loading: 'lazy', alt: media_alt
              }}

            {% when 'video' %}
              {{
                media | video_tag: class: 'product-media__video', controls: true, preload: 'metadata', image_size: '1200x'
              }}

            {% when 'external_video' %}
              {{
                media | external_video_tag: class: 'product-media__external-video'
              }}

            {% when 'model' %}
              {{
                media | model_viewer_tag: class: 'product-media__model', reveal: 'interaction', toggleable: true
              }}
          {% endcase %}
        </div>
      {% endfor %}
    </div>

    {% if product.media.size > 1 %}
      <nav class="product-media__thumbnails" aria-label="Product media">
        <ul class="product-media__thumbnail-list">
          {% for media in product.media %}
            <li>
              <a
                class="product-media__thumbnail"
                href="#ProductMedia-{{ section.id }}-{{ media.id }}"
                aria-label="View media {{ forloop.index }} of {{ product.media.size }}">
                {{
                  media.preview_image | image_url: width: 160 | image_tag: class: 'product-media__thumbnail-image', widths: '80, 120, 160', sizes: '80px', loading: 'lazy', alt: ''
                }}

                {% unless media.media_type == 'image' %}
                  <span class="product-media__type">
                    {{ media.media_type | replace: '_', ' ' }}
                  </span>
                {% endunless %}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}
  {% else %}
    <div class="product-media__empty">
      No product media has been added.
    </div>
  {% endif %}
</div>